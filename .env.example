# Site configuration
# In Astro, public env vars must be prefixed with PUBLIC_

# Custom site name (default: NoUploads)
PUBLIC_SITE_NAME=NoUploads

# Deployment URL — used for sitemap, OG tags, canonical URLs (default: https://nouploads.com)
PUBLIC_SITE_URL=https://nouploads.com

# GitHub repo URL (default: https://github.com/nouploads/nouploads)
PUBLIC_GITHUB_URL=https://github.com/nouploads/nouploads
