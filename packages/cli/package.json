{
	"name": "nouploads",
	"version": "0.1.0",
	"description": "Convert and process files locally — no uploads, no servers. CLI tool and library.",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"nouploads": "./bin/nouploads.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsup && api-extractor run --local --verbose",
		"test": "vitest run",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@clack/prompts": "1.1.0",
		"@webtoon/psd": "0.4.0",
		"commander": "14.0.3",
		"exifr": "7.1.3",
		"fast-xml-parser": "5.6.0",
		"fflate": "0.8.2",
		"js-beautify": "1.15.4",
		"js-yaml": "4.1.1",
		"pdf-lib": "1.17.1",
		"qrcode": "1.5.4",
		"sharp": "0.34.5",
		"sql-formatter": "15.7.3",
		"svgo": "4.0.1",
		"utif2": "4.1.0"
	},
	"devDependencies": {
		"@microsoft/api-extractor": "7.58.4",
		"@nouploads/backend-sharp": "workspace:*",
		"@nouploads/core": "workspace:*",
		"@types/node": "24.12.0",
		"tsup": "8.5.1"
	},
	"keywords": [
		"image-converter",
		"heic",
		"avif",
		"webp",
		"pdf",
		"file-conversion",
		"cli",
		"no-upload",
		"offline",
		"privacy"
	],
	"license": "MIT",
	"homepage": "https://nouploads.com",
	"engines": {
		"node": ">=22.0.0"
	}
}
