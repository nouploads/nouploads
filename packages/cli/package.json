{
	"name": "nouploads",
	"version": "0.1.0",
	"description": "Convert and process files locally — no uploads, no servers. CLI tool and library.",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"nouploads": "./bin/nouploads.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsup",
		"test": "vitest run",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@nouploads/core": "workspace:*",
		"@nouploads/backend-sharp": "workspace:*",
		"commander": "14.0.3",
		"@clack/prompts": "1.1.0"
	},
	"devDependencies": {
		"@types/node": "24.12.0",
		"tsup": "8.5.1"
	},
	"keywords": [
		"image-converter",
		"heic",
		"avif",
		"webp",
		"pdf",
		"file-conversion",
		"cli",
		"no-upload",
		"offline",
		"privacy"
	],
	"license": "MIT",
	"homepage": "https://nouploads.com",
	"engines": {
		"node": ">=24.14.0"
	}
}
