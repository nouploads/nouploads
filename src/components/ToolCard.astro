---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
  comingSoon?: boolean;
}

const { title, description, href, icon, comingSoon = false } = Astro.props;
---

<a
  href={comingSoon ? undefined : href}
  class:list={[
    "group block rounded-lg border bg-card p-5 transition-all",
    comingSoon ? "opacity-60 cursor-default" : "hover:border-primary/40 hover:shadow-md",
  ]}
>
  <div class="flex items-start gap-3">
    <span class="text-2xl" role="img" aria-hidden="true">{icon}</span>
    <div class="min-w-0">
      <h3 class="font-semibold text-card-foreground group-hover:text-primary transition-colors flex items-center gap-2">
        {title}
        {comingSoon && (
          <span class="text-xs font-normal bg-muted text-muted-foreground px-2 py-0.5 rounded-full">Soon</span>
        )}
      </h3>
      <p class="text-sm text-muted-foreground mt-1">{description}</p>
    </div>
  </div>
</a>
