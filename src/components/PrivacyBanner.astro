---
import { Lock } from '@lucide/astro';
---

<div class="bg-primary/5 border border-primary/20 rounded-lg px-4 py-3 text-sm flex items-center gap-2">
  <Lock class="h-4 w-4 text-primary shrink-0" />
  <span class="text-muted-foreground">
    <strong class="text-foreground">Your files never leave your device.</strong>
    All processing happens in your browser.
    <a href="/about" class="text-primary underline underline-offset-2 hover:text-primary/80 transition-colors whitespace-nowrap">Verify&nbsp;&rarr;</a>
  </span>
</div>
