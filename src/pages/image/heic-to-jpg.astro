---
import ToolLayout from '../../layouts/ToolLayout.astro';
import HeicConverter from '../../components/tools/HeicConverter.tsx';

const title = 'Convert HEIC to JPG Online — Free, Private, No Upload | NoUploads';
const description = 'Convert iPhone HEIC photos to JPG format instantly in your browser. No upload, no server, 100% private. Works offline.';
---

<ToolLayout title={title} description={description}>
  <h1 class="text-3xl font-bold mb-2">Convert HEIC to JPG</h1>
  <p class="text-muted-foreground mb-6">
    Convert iPhone HEIC photos to universal JPG format. Your files never leave your device.
  </p>

  <!-- Interactive React component -->
  <HeicConverter client:load />

  <!-- Static SEO content -->
  <section class="mt-12 space-y-8 text-muted-foreground">
    <div>
      <h2 class="text-xl font-semibold text-foreground mb-2">How it works</h2>
      <p>
        NoUploads converts your HEIC files to JPG entirely in your browser using JavaScript.
        Your photos are never uploaded to any server — the conversion happens locally on your device.
        You can verify this by checking the Network tab in your browser's developer tools,
        or by turning on airplane mode — it still works.
      </p>
    </div>

    <div>
      <h2 class="text-xl font-semibold text-foreground mb-2">Frequently asked questions</h2>

      <div class="space-y-4">
        <div>
          <h3 class="font-medium text-foreground">What is a HEIC file?</h3>
          <p>
            HEIC (High Efficiency Image Container) is the default photo format on iPhones and iPads
            running iOS 11 or later. It produces smaller file sizes than JPG while maintaining the
            same image quality. However, many apps, websites, and older devices don't support HEIC.
          </p>
        </div>

        <div>
          <h3 class="font-medium text-foreground">Why convert HEIC to JPG?</h3>
          <p>
            JPG is the most universally supported image format. Converting HEIC to JPG ensures your
            photos can be opened anywhere — on any device, any browser, any app. It's especially
            useful when sharing photos with people who don't use Apple devices.
          </p>
        </div>

        <div>
          <h3 class="font-medium text-foreground">Is it safe to convert files here?</h3>
          <p>
            Yes. All processing happens locally on your device. Your photos are never uploaded to any
            server. You can verify this by opening your browser's Network tab (F12 → Network) while
            converting — you'll see zero file uploads. You can also disconnect from the internet
            after the page loads and the tool will continue to work.
          </p>
        </div>

        <div>
          <h3 class="font-medium text-foreground">What quality should I use?</h3>
          <p>
            The default quality of 92% provides an excellent balance between file size and image quality.
            For most purposes, anything above 85% is visually indistinguishable from the original.
            Lower quality values produce smaller files but may introduce visible compression artifacts.
          </p>
        </div>

        <div>
          <h3 class="font-medium text-foreground">Is there a file size limit?</h3>
          <p>
            Since processing happens in your browser, the limit depends on your device's available
            memory. Most modern devices can handle photos up to 50MB+ without issues. For very large
            files, make sure you have sufficient free memory.
          </p>
        </div>
      </div>
    </div>
  </section>
</ToolLayout>
