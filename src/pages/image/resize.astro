---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Resize Images Online — Free, Private, No Upload | NoUploads';
const description = 'Resize images by pixels, percentage, or social media presets. All processing happens in your browser. No upload, 100% private.';
---

<ToolLayout title={title} description={description}>
  <h1 class="text-3xl font-bold mb-2">Resize Images</h1>
  <p class="text-muted-foreground mb-6">
    Resize by pixels, percentage, or social media presets. Your files never leave your device.
  </p>

  <div class="rounded-lg border-2 border-dashed border-muted-foreground/25 p-12 text-center">
    <p class="text-2xl mb-2">📐</p>
    <p class="font-medium text-lg">Coming soon</p>
    <p class="text-sm text-muted-foreground mt-1">This tool is under development. Check back soon!</p>
  </div>

  <section class="mt-12 space-y-8 text-muted-foreground">
    <div>
      <h2 class="text-xl font-semibold text-foreground mb-2">How it works</h2>
      <p>
        NoUploads resizes your images using the browser's Canvas API. Set your target dimensions by
        exact pixels, percentage, or choose from social media presets (Instagram, Twitter, Facebook, etc.).
        Aspect ratio lock ensures your images don't get distorted.
      </p>
    </div>

    <div>
      <h2 class="text-xl font-semibold text-foreground mb-2">Frequently asked questions</h2>
      <div class="space-y-4">
        <div>
          <h3 class="font-medium text-foreground">Can I maintain the aspect ratio?</h3>
          <p>Yes. Aspect ratio lock is enabled by default. Set one dimension and the other adjusts automatically.</p>
        </div>
        <div>
          <h3 class="font-medium text-foreground">What social media presets are available?</h3>
          <p>Presets for Instagram post (1080x1080), Instagram story (1080x1920), Twitter header (1500x500), Facebook cover (820x312), and more.</p>
        </div>
      </div>
    </div>
  </section>
</ToolLayout>
