---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'EXIF Viewer & Remover — View or Strip Photo Metadata | NoUploads';
const description = 'View EXIF data (camera, GPS, date) or strip metadata from photos. All processing in your browser. No upload, 100% private.';
---

<ToolLayout title={title} description={description}>
  <h1 class="text-3xl font-bold mb-2">EXIF Viewer & Remover</h1>
  <p class="text-muted-foreground mb-6">
    View or strip photo metadata (camera info, GPS location, date). Your files never leave your device.
  </p>

  <div class="rounded-lg border-2 border-dashed border-muted-foreground/25 p-12 text-center">
    <p class="text-2xl mb-2">🔍</p>
    <p class="font-medium text-lg">Coming soon</p>
    <p class="text-sm text-muted-foreground mt-1">This tool is under development. Check back soon!</p>
  </div>

  <section class="mt-12 space-y-8 text-muted-foreground">
    <div>
      <h2 class="text-xl font-semibold text-foreground mb-2">How it works</h2>
      <p>
        Photos contain hidden metadata called EXIF data — camera model, settings, GPS coordinates,
        date and time, and more. This tool lets you view all metadata in a table, or strip it completely
        before sharing your photos. Everything runs in your browser.
      </p>
    </div>

    <div>
      <h2 class="text-xl font-semibold text-foreground mb-2">Frequently asked questions</h2>
      <div class="space-y-4">
        <div>
          <h3 class="font-medium text-foreground">What is EXIF data?</h3>
          <p>EXIF (Exchangeable Image File Format) is metadata embedded in photos by cameras and phones. It can include camera settings, GPS location, date/time, and device information.</p>
        </div>
        <div>
          <h3 class="font-medium text-foreground">Why should I remove EXIF data?</h3>
          <p>EXIF data can include your GPS location, revealing where a photo was taken. Removing it before sharing photos online protects your privacy.</p>
        </div>
      </div>
    </div>
  </section>
</ToolLayout>
