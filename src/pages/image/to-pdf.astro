---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Images to PDF — Combine Images into PDF | NoUploads';
const description = 'Combine multiple images into a single PDF file. Drag to reorder. All processing in your browser. No upload, 100% private.';
---

<ToolLayout title={title} description={description}>
  <h1 class="text-3xl font-bold mb-2">Images to PDF</h1>
  <p class="text-muted-foreground mb-6">
    Combine multiple images into a single PDF. Drag to reorder. Your files never leave your device.
  </p>

  <div class="rounded-lg border-2 border-dashed border-muted-foreground/25 p-12 text-center">
    <p class="text-2xl mb-2">📄</p>
    <p class="font-medium text-lg">Coming soon</p>
    <p class="text-sm text-muted-foreground mt-1">This tool is under development. Check back soon!</p>
  </div>

  <section class="mt-12 space-y-8 text-muted-foreground">
    <div>
      <h2 class="text-xl font-semibold text-foreground mb-2">How it works</h2>
      <p>
        Upload multiple images, drag to reorder them, then combine them into a single PDF document.
        Uses pdf-lib for client-side PDF creation — your images are never uploaded to any server.
        The resulting PDF preserves image quality and can be downloaded instantly.
      </p>
    </div>

    <div>
      <h2 class="text-xl font-semibold text-foreground mb-2">Frequently asked questions</h2>
      <div class="space-y-4">
        <div>
          <h3 class="font-medium text-foreground">What image formats are supported?</h3>
          <p>JPG, PNG, and WebP images can be combined into a PDF. Each image becomes one page in the output PDF.</p>
        </div>
        <div>
          <h3 class="font-medium text-foreground">Can I reorder the images?</h3>
          <p>Yes. After uploading, drag and drop images to arrange them in your preferred order before creating the PDF.</p>
        </div>
        <div>
          <h3 class="font-medium text-foreground">Is there a limit on the number of images?</h3>
          <p>There's no hard limit, but very large numbers of high-resolution images may be constrained by your device's available memory.</p>
        </div>
      </div>
    </div>
  </section>
</ToolLayout>
