---
import ToolLayout from '../../layouts/ToolLayout.astro';

const title = 'Compress Images Online — Free, Private, No Upload | NoUploads';
const description = 'Reduce image file sizes with adjustable quality. Compress JPG, PNG, and WebP images in your browser. No upload, 100% private.';
---

<ToolLayout title={title} description={description}>
  <h1 class="text-3xl font-bold mb-2">Compress Images</h1>
  <p class="text-muted-foreground mb-6">
    Reduce image file sizes with adjustable quality. Your files never leave your device.
  </p>

  <!-- Tool coming soon placeholder -->
  <div class="rounded-lg border-2 border-dashed border-muted-foreground/25 p-12 text-center">
    <p class="text-2xl mb-2">🗜️</p>
    <p class="font-medium text-lg">Coming soon</p>
    <p class="text-sm text-muted-foreground mt-1">This tool is under development. Check back soon!</p>
  </div>

  <section class="mt-12 space-y-8 text-muted-foreground">
    <div>
      <h2 class="text-xl font-semibold text-foreground mb-2">How it works</h2>
      <p>
        NoUploads compresses your images entirely in your browser using the native Canvas API.
        Adjust the quality slider to find the perfect balance between file size and visual quality.
        All processing happens locally — your images are never uploaded to any server.
      </p>
    </div>

    <div>
      <h2 class="text-xl font-semibold text-foreground mb-2">Frequently asked questions</h2>
      <div class="space-y-4">
        <div>
          <h3 class="font-medium text-foreground">What formats can I compress?</h3>
          <p>You can compress JPG, PNG, and WebP images. Each format uses different compression methods optimized for the format type.</p>
        </div>
        <div>
          <h3 class="font-medium text-foreground">Will I lose image quality?</h3>
          <p>You control the compression level. Higher quality settings preserve more detail but result in larger files. For most uses, 80-90% quality is visually identical to the original.</p>
        </div>
        <div>
          <h3 class="font-medium text-foreground">Is there a file size limit?</h3>
          <p>Since processing happens in your browser, limits depend on your device's memory. Most modern devices handle images up to 50MB without issues.</p>
        </div>
      </div>
    </div>
  </section>
</ToolLayout>
