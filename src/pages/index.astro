---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ToolFilter from '../components/ToolFilter.tsx';
import { Lock, CircleCheck, Power } from '@lucide/astro';
import { tools } from '@/lib/tools';

const title = 'NoUploads — Privacy-First File Tools | 100% Client-Side';
const description = 'Free online file tools that run entirely in your browser. Convert, compress, resize images and more. No uploads, no servers, 100% private.';

const issuesUrl = import.meta.env.PUBLIC_GITHUB_URL
  ? `${import.meta.env.PUBLIC_GITHUB_URL}/issues`
  : 'https://github.com/nouploads/nouploads/issues';
---

<BaseLayout title={title} description={description}>
  <Header />

  <main class="mx-auto w-full max-w-6xl flex-1 px-4">
    <!-- Hero -->
    <section class="py-16 md:py-24 text-center">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">
        Privacy-first file tools.
        <br />
        <span class="text-primary">Everything runs in your browser.</span>
      </h1>
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto mb-8">
        Other tools upload your files to someone else's server &mdash;<br class="hidden sm:inline" />
        your personal photos, work documents, private files.<br />
        We don't. Your files never leave your device.
      </p>
      <div class="flex items-center justify-center gap-3 text-sm text-muted-foreground">
        <span class="flex items-center gap-1.5">
          <Lock class="h-4 w-4 text-primary" />
          No uploads
        </span>
        <span class="text-border">|</span>
        <span class="flex items-center gap-1.5">
          <CircleCheck class="h-4 w-4 text-primary" />
          Free &amp; open source
        </span>
        <span class="text-border">|</span>
        <span class="flex items-center gap-1.5">
          <Power class="h-4 w-4 text-primary" />
          Works offline
        </span>
      </div>
    </section>

    <!-- Tool Grid with Filter -->
    <section class="pb-16">
      <ToolFilter client:load tools={tools} issuesUrl={issuesUrl} />
    </section>

    <!-- How it works -->
    <section class="pb-16 max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold mb-6 text-center">How it works</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center">
        <div>
          <div class="text-3xl mb-2">1</div>
          <h3 class="font-semibold mb-1">Choose a tool</h3>
          <p class="text-sm text-muted-foreground">Pick from our growing collection of file conversion and manipulation tools.</p>
        </div>
        <div>
          <div class="text-3xl mb-2">2</div>
          <h3 class="font-semibold mb-1">Drop your files</h3>
          <p class="text-sm text-muted-foreground">Drag and drop your files. Nothing leaves your device. Ever.</p>
        </div>
        <div>
          <div class="text-3xl mb-2">3</div>
          <h3 class="font-semibold mb-1">Download results</h3>
          <p class="text-sm text-muted-foreground">Processing happens instantly in your browser. Download the result when it's done.</p>
        </div>
      </div>
    </section>

    <!-- Verify -->
    <section class="pb-16 max-w-2xl mx-auto">
      <div class="rounded-xl border-2 border-primary/20 bg-primary/5 p-8 text-center">
        <h2 class="text-xl font-bold mb-2">Don't trust us? Verify yourself.</h2>
        <p class="text-sm text-muted-foreground max-w-lg mx-auto mb-4">
          Open your browser's Network tab (F12 &rarr; Network) while using any tool. You'll see zero file uploads.
          Or turn on airplane mode after the page loads &mdash; everything still works.
        </p>
        <a href="/about" class="inline-flex items-center gap-1 text-sm font-medium text-primary hover:text-primary/80 transition-colors">
          Learn more &rarr;
        </a>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
