---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Page Not Found — NoUploads" description="The page you're looking for doesn't exist.">
  <Header />

  <main class="mx-auto max-w-3xl px-4 py-24 text-center">
    <h1 class="text-6xl font-bold text-muted-foreground/30 mb-4">404</h1>
    <p class="text-xl font-medium mb-2">Page not found</p>
    <p class="text-muted-foreground mb-6">The page you're looking for doesn't exist or has been moved.</p>
    <a href="/" class="inline-flex items-center gap-2 text-primary hover:underline underline-offset-2">
      ← Back to tools
    </a>
  </main>

  <Footer />
</BaseLayout>
