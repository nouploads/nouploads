# Site configuration
# In Vite, public env vars must be prefixed with VITE_

# Custom site name (default: NoUploads)
VITE_SITE_NAME=NoUploads

# Deployment URL — used for sitemap, OG tags, canonical URLs (default: https://nouploads.com)
VITE_SITE_URL=https://nouploads.com

# GitHub repo URL (default: https://github.com/nouploads/nouploads)
VITE_GITHUB_URL=https://github.com/nouploads/nouploads
