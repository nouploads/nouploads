{
	"name": "nouploads-monorepo",
	"version": "0.4.0",
	"private": true,
	"description": "Privacy-first file tools that run entirely on your device — no uploads, no servers",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/nouploads/nouploads.git"
	},
	"homepage": "https://nouploads.com",
	"bugs": {
		"url": "https://github.com/nouploads/nouploads/issues"
	},
	"scripts": {
		"build": "turbo run build",
		"generate:og": "npx tsx scripts/generate-og-images.ts",
		"test": "turbo run test",
		"dev": "turbo run dev --parallel",
		"lint": "turbo run lint",
		"lint:fix": "turbo run lint:fix",
		"clean": "turbo run clean",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"husky": "9.1.7",
		"turbo": "2.8.21",
		"typescript": "5.9.3",
		"vitest": "4.1.1"
	},
	"packageManager": "pnpm@9.15.4"
}
